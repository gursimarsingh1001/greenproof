generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                    Int                    @id @default(autoincrement())
  name                  String
  brandId               Int
  brand                 Brand                  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  barcode               String                 @unique
  category              String
  description           String?
  imageUrl              String?
  priceCents            Int?
  dataSource            String                 @default("local_seed")
  sourceUrl             String?
  sourceMetadata        Json?
  // SQLite cannot store primitive string lists directly, so claims are kept as a JSON array.
  claims                Json                   @default("[]")
  productCertifications ProductCertification[]
  productAliases        ProductAlias[]
  certificationEvidence CertificationEvidence[] @relation("ProductEvidence")
  verificationSnapshots VerificationSnapshot[]
  feedback              Feedback[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([brandId])
  @@index([category])
  @@index([dataSource])
  @@index([name])
  @@unique([name, brandId])
}

model Brand {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  website             String?
  isFlagged           Boolean              @default(false)
  flagReason          String?
  reputationScore     Float                @default(0.5)
  products            Product[]
  brandAliases        BrandAlias[]
  brandCertifications BrandCertification[]
  certificationEvidence CertificationEvidence[] @relation("BrandEvidence")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([reputationScore])
}

model Certification {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @unique
  acronym               String                 @unique
  issuingBody           String
  scope                 String
  brandCertifications   BrandCertification[]
  certificationEvidence CertificationEvidence[]
  productCertifications ProductCertification[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model CertificationSource {
  id                    String                  @id
  sector                String
  certificationName     String
  databaseUrl           String
  liveFetchUrl          String?
  access                String
  notes                 String
  coverageHint          String?
  isOfficial            Boolean                 @default(true)
  isSupported           Boolean                 @default(false)
  wave                  Int                     @default(1)
  priority              Int                     @default(100)
  certificationEvidence CertificationEvidence[]
  ingestionRuns         CertificationIngestionRun[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([sector, priority])
  @@index([wave])
  @@index([isSupported])
}

model CertificationEvidence {
  id                Int                       @id @default(autoincrement())
  sourceId          String
  certificationId   Int
  scope             String
  status            String                    @default("verified")
  matchedVia        String                    @default("exact")
  confidence        Float                     @default(1)
  externalBrandName String
  externalProductName String?
  certificateNumber String?
  sourceUrl         String?
  rawPayload        Json?
  checkedAt         DateTime
  expiresAt         DateTime?
  firstSeenAt       DateTime                  @default(now())
  brandId           Int?
  productId         Int?
  ingestionRunId    Int?
  certification     Certification             @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  source            CertificationSource       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  brand             Brand?                    @relation("BrandEvidence", fields: [brandId], references: [id], onDelete: SetNull)
  product           Product?                  @relation("ProductEvidence", fields: [productId], references: [id], onDelete: SetNull)
  ingestionRun      CertificationIngestionRun? @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([sourceId, checkedAt])
  @@index([brandId, status])
  @@index([productId, status])
  @@index([certificationId, status])
  @@index([scope, status])
}

model CertificationIngestionRun {
  id               Int                     @id @default(autoincrement())
  sourceId         String?
  sector           String?
  mode             String
  status           String
  query            String?
  recordsFetched   Int                     @default(0)
  recordsMatched   Int                     @default(0)
  recordsProjected Int                     @default(0)
  errorMessage     String?
  startedAt        DateTime                @default(now())
  finishedAt       DateTime?
  source           CertificationSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  evidence         CertificationEvidence[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([sourceId, startedAt])
  @@index([sector, startedAt])
  @@index([status])
}

model BrandAlias {
  id        Int      @id @default(autoincrement())
  brandId    Int
  alias      String
  isPrimary  Boolean  @default(false)
  brand      Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([brandId, alias])
  @@index([alias])
}

model ProductAlias {
  id        Int      @id @default(autoincrement())
  productId  Int
  alias      String
  isPrimary  Boolean  @default(false)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, alias])
  @@index([alias])
}

model BrandCertification {
  brandId           Int
  certificationId   Int
  certificateNumber String?
  isValid           Boolean       @default(false)
  expiryDate        DateTime?
  brand             Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  certification     Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@id([brandId, certificationId])
}

model ProductCertification {
  productId         Int
  certificationId   Int
  certificateNumber String?
  isVerified        Boolean       @default(false)
  product           Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  certification     Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@id([productId, certificationId])
}

model VagueTerm {
  term        String   @id
  category    String
  penalty     Int      @default(-20)
  explanation String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ImpossibleClaim {
  claimPattern String   @id
  reason       String
  penalty      Int      @default(-40)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Feedback {
  id            Int      @id @default(autoincrement())
  productId     Int?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  issueType     String   @default("other")
  message       String
  email         String?
  reportedScore Int?
  expectedScore Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([createdAt])
}

model VerificationSnapshot {
  id               Int      @id @default(autoincrement())
  productId        Int
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  displayId        String   @unique
  resultHash       String
  algorithmVersion String
  canonicalPayload Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([productId])
  @@index([createdAt])
  @@index([productId, resultHash, algorithmVersion])
}
