# Postgres-first default for the official-certification rollout.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/greenproof?schema=public"
GREENPROOF_DB_PROVIDER="postgresql"
GREENPROOF_POSTGRES_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/greenproof?schema=public"

# Local SQLite fallback for quick demos/tests:
# DATABASE_URL="file:./dev.db"
# GREENPROOF_DB_PROVIDER="sqlite"
# GREENPROOF_SQLITE_DATABASE_URL="file:./dev.db"

NODE_ENV="development"
PORT="4000"
CRON_SECRET="replace-with-a-long-random-string"
OFFICIAL_EVIDENCE_SYNC_DIR=""
OPEN_FOOD_FACTS_BASE_URL="https://world.openfoodfacts.org/api/v2"
NEWS_API_KEY=""
GOOGLE_CUSTOM_SEARCH_API_KEY=""
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=""
